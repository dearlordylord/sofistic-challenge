{
  "name": "@sofistic/transactions-clean",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm -C ../transactions-shared build && tsc -b --force tsconfig.json",
    "materialize": "tsx scripts/materialize-canonical-model.mjs",
    "typecheck": "pnpm -C ../transactions-shared build && tsc -p tsconfig.json --noEmit",
    "test": "vitest run src --config ../../vitest.config.ts --coverage.enabled=false",
    "test:coverage": "vitest run src --config ../../vitest.config.ts --coverage.enabled=true",
    "lint": "eslint src scripts && jscpd src",
    "lint:fix": "eslint src scripts --fix",
    "format": "eslint src scripts --fix --rule '@effect/dprint: error'",
    "check-format": "eslint src scripts --rule '@effect/dprint: error'",
    "circular": "madge --extensions ts --circular src"
  },
  "dependencies": {
    "@sofistic/transactions-shared": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.22.5"
  }
}
